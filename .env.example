# ═══════════════════════════════════════════════════════════════════════════
#  AuditLens — конфигурация окружения
#
#  Скопируй этот файл в `.env` и заполни значения:
#      cp .env.example .env
#  Файл `.env` ИГНОРИРУЕТСЯ git'ом (см. .gitignore) — туда можно класть
#  реальные ключи без риска утечки.
# ═══════════════════════════════════════════════════════════════════════════

# ── База данных (обязательно) ─────────────────────────────────────────────
# Если запускаешь Postgres через docker-compose из репозитория — оставь как есть.
# Если используешь свой Postgres — поменяй DSN. Требуется расширение pgvector.
DATABASE_URL=postgresql+psycopg://audit:audit@localhost:5432/bank_audit

# ── LLM-провайдер (обязательно) ───────────────────────────────────────────
# Используется OpenAI-совместимый endpoint. По умолчанию — Fireworks AI:
#   • 15 USD бесплатных кредитов при регистрации (хватает на ~30-50 deep-research'ей)
#   • Подключение без VPN из РФ
#   • Список моделей: https://fireworks.ai/models
# Как получить ключ → docs/API_KEYS.md
LLM_MODE=api
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_API_KEY=fw_REPLACE_WITH_YOUR_KEY
LLM_MODEL_NAME=accounts/fireworks/models/gpt-oss-120b

# Гибридная модель (опционально, но рекомендуется):
#   FAST  — для рутины (планировщик, резолвер, графики): быстро, structured JSON.
#   SMART — для глубокого reasoning (синтез, fact-extraction, merge): качественнее.
# По умолчанию оба = gpt-oss-120b (single-pass, без reasoning-leak).
LLM_MODEL_FAST=accounts/fireworks/models/gpt-oss-120b
LLM_MODEL_SMART=accounts/fireworks/models/gpt-oss-120b

# Ключи для нативных провайдеров, используемых nanobot-агентом лазеек.
# Если выбрана модель Gemini / Qwen, а ключ пуст, используется LLM_API_KEY выше.
# GEMINI_API_KEY=YOUR_GEMINI_KEY
# DASHSCOPE_API_KEY=YOUR_DASHSCOPE_KEY

# ── Web search backends ───────────────────────────────────────────────────
# Порядок fallback: SearXNG → Brave → DDG → Yandex.
# Если поднял SearXNG локально через docker-compose — оставь URL как есть.
# Без SearXNG система автоматически fallback'нется на Brave/DDG.
SEARXNG_URL=http://localhost:8888

# Brave Search API — 2000 запросов/мес бесплатно. Опционально.
# Регистрация: https://api.search.brave.com/app/keys
# BRAVE_SEARCH_API_KEY=BSA...

# ── Browser automation (опционально) ──────────────────────────────────────
# Путь к профилю Comet/Chrome для обхода Cloudflare/captcha на сложных страницах.
# Если не используешь — оставь пустым, fetcher отработает через httpx.
# OPENCLAW_BROWSER_PROFILE=/Users/<you>/Library/Application Support/Comet_audit

# ── HTTP-запросы ──────────────────────────────────────────────────────────
HTTP_USER_AGENT=AuditLensBot/1.0 (+internal-audit)
DEFAULT_REQUEST_DELAY_MS=1500
MAX_RETRIES=3

# ── Хранилище ─────────────────────────────────────────────────────────────
WORKSPACE_DIR=./workspace
LOG_LEVEL=INFO

# ── Email-алерты (опционально) ────────────────────────────────────────────
# Без SMTP_USER/PWD/FROM/TO алерты не отправляются — тихий пропуск.
# SMTP_HOST=smtp.example.ru
# SMTP_PORT=2525
# SMTP_USER=login@example.ru
# SMTP_PWD=password
# SMTP_FROM=audit-bot@example.ru
# ALERTS_TO=audit-team@example.ru
# ALERTS_CC=
ALERTS_INTERVAL_S=1800
ALERTS_LOOKBACK_M=60

# ── Embeddings ────────────────────────────────────────────────────────────
# BGE-M3 — multilingual, 1024d. Загружается лениво при первом запросе (~2GB).
# Альтернатива для слабых машин: intfloat/multilingual-e5-small (470MB, 384d).
# При смене модели сменить EMBEDDING_DIM и пересоздать migrations/005.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKENS=512
