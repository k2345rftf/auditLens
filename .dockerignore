# ── Секреты — НИКОГДА не должны попасть в образ ──────────────────────────────
.env
.env.local
.env.*.local
**/secrets/
**/*.key

# ── venv / git / Python-кэши (рекурсивно: иначе вложенные не матчатся) ────────
.venv/
venv/
env/
ENV/
.git/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage*

