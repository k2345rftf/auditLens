# ════════════════════════════════════════════════════════════════════════════
#  AuditLens — ШАБЛОН прод-окружения для контейнера (Облако УВА).
#
#  Это ОБРАЗЕЦ. На VM вертикали реальные значения берутся из Infisical (env-инжект)
#  ИЛИ кладутся в файл .env рядом с docker-compose.prod.yml (в образ .env НЕ попадает).
#  СЕКРЕТЫ помечены [SECRET] — их источник Infisical, в git/образ не коммитить.
# ════════════════════════════════════════════════════════════════════════════

# ── База данных: managed PostgreSQL + pgvector (схема auditlens) ──────────────
# [SECRET] содержит пароль. Схема задаётся через ?options=-csearch_path=auditlens
# (percent-encoded), либо ОАИТ ставит default search_path на роль.
DATABASE_URL=postgresql+psycopg://auditlens_app:CHANGE_ME@10.0.3.43:5432/oarb_auditlens?options=-csearch_path%3Dauditlens

# ── LLM: Foundation Models cloud.ru (OpenAI-совместимый) ─────────────────────
LLM_MODE=api
LLM_BASE_URL=https://foundation-models.api.cloud.ru/v1/
LLM_API_KEY=CHANGE_ME                       # [SECRET] ключ Foundation Models
# Внутренние модели (комплаентный дефолт). Внешние (gemini/claude/gpt) — по согласованию.
LLM_MODEL_NAME=openai/gpt-oss-120b
LLM_MODEL_FAST=openai/gpt-oss-120b
LLM_MODEL_SMART=openai/gpt-oss-120b
LLM_MODEL_REASONING=openai/gpt-oss-120b
LLM_MODEL_ANALYST=openai/gpt-oss-120b
LLM_REASONING_EFFORT=low
LLM_REASONING_EFFORT_DEEP=medium
# Альтернатива (лучшее качество, ВНЕШНИЕ модели — согласовать с ОАИТ):
#   LLM_MODEL_REASONING=google/gemini-3.1-pro-preview
#   LLM_MODEL_ANALYST=google/gemini-3.1-pro-preview
#   LLM_MODEL_FAST=google/gemini-2.5-flash
#   LLM_MODEL_SMART=google/gemini-2.5-flash

# ── Эмбеддинги через API (НЕ грузим torch; bge-m3 1024d) ─────────────────────
EMBEDDING_MODE=api
EMBEDDING_BASE_URL=https://foundation-models.api.cloud.ru/v1/
EMBEDDING_API_KEY=CHANGE_ME                 # [SECRET] (или оставить пустым → fallback на LLM_API_KEY)
EMBEDDING_API_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKENS=512

# ── Веб-поиск ────────────────────────────────────────────────────────────────
# В docker-compose.prod.yml SEARXNG_URL уже выставлен в http://searxng:8080 (sidecar).
SEARXNG_URL=http://searxng:8080
# BRAVE_SEARCH_API_KEY=                      # [SECRET] опционально

# ── Рантайм / хранилище ──────────────────────────────────────────────────────
WORKSPACE_DIR=/app/workspace                 # смонтирован volume; для постоянства — OBS
LOG_LEVEL=INFO
HTTP_USER_AGENT=AuditLensBot/1.0 (+internal-audit)
CA_BUNDLE_PATH=/app/config/ca_bundle_combined.pem
# За реверс-прокси фронт и API на одном origin → CORS не нужен. Укажите СВОЙ поддомен
# (а не "*"). Пустое значение полностью выключает CORS-middleware.
CORS_ALLOW_ORIGINS=https://auditlens.uva-advanced.ru

# ── SMTP-алерты (опционально; без логина/пароля алерты тихо выключены) ────────
# SMTP_HOST=smtp.omega.sbrf.ru
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PWD=                                   # [SECRET]
# SMTP_FROM=
# ALERTS_TO=

# ── НЕ задавать в проде ───────────────────────────────────────────────────────
# DEMO_MODE                 (демо-стрим вместо реального пайплайна)
# OPENCLAW_BROWSER_PROFILE  (путь macOS, невалиден в Linux-контейнере)
# OPENAI_API_KEY            (дубль LLM_API_KEY)
